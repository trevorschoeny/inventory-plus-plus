{
  "schemaVersion": 1,
  "id": "inventorymax",
  "version": "${version}",
  "name": "Inventory Max",
  "description": "Server-side companion to Inventory Plus: container locks, elytra + totem equipment slots, and persistent pocket slots.",
  "authors": ["trevorschoeny"],
  "license": "MIT",
  "environment": "*",
  "mixins": [
    "inventorymax.mixins.json"
  ],
  "entrypoints": {
    "main": ["com.trevorschoeny.inventorymax.InventoryMax"],
    "client": ["com.trevorschoeny.inventorymax.InventoryMaxClient"],
    "modmenu": ["com.trevorschoeny.inventorymax.config.IMConfigModMenu"]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.21",
    "menukit": ">=2.0.0",
    "menukit-containers": ">=2.0.0",
    "inventoryplus": ">=1.2.0"
  }
}
